# =============================================================================
# LibreTime Multi-Station - EstacionKusMedios Digital
# =============================================================================
# Este archivo es una plantilla. Copia a .env y reemplaza los valores.
# El script setup.sh genera contraseñas automáticamente.
# =============================================================================

# Versión de LibreTime
LIBRETIME_VERSION=4.5.0

# =============================================================================
# Estación 1: Runaradio
# =============================================================================
RUNARADIO_POSTGRES_PASSWORD=CHANGE_ME
RUNARADIO_RABBITMQ_PASS=CHANGE_ME
RUNARADIO_ICECAST_SOURCE_PASSWORD=CHANGE_ME
RUNARADIO_ICECAST_ADMIN_PASSWORD=CHANGE_ME
RUNARADIO_ICECAST_RELAY_PASSWORD=CHANGE_ME
RUNARADIO_API_KEY=CHANGE_ME
RUNARADIO_SECRET_KEY=CHANGE_ME
RUNARADIO_PUBLIC_URL=http://localhost:8081

# =============================================================================
# Estación 2: EstacionKusFM
# =============================================================================
ESTACIONKUSFM_POSTGRES_PASSWORD=CHANGE_ME
ESTACIONKUSFM_RABBITMQ_PASS=CHANGE_ME
ESTACIONKUSFM_ICECAST_SOURCE_PASSWORD=CHANGE_ME
ESTACIONKUSFM_ICECAST_ADMIN_PASSWORD=CHANGE_ME
ESTACIONKUSFM_ICECAST_RELAY_PASSWORD=CHANGE_ME
ESTACIONKUSFM_API_KEY=CHANGE_ME
ESTACIONKUSFM_SECRET_KEY=CHANGE_ME
ESTACIONKUSFM_PUBLIC_URL=http://localhost:8082

# =============================================================================
# Estación 3: RadioAventuraMX
# =============================================================================
RADIOAVENTURAMX_POSTGRES_PASSWORD=CHANGE_ME
RADIOAVENTURAMX_RABBITMQ_PASS=CHANGE_ME
RADIOAVENTURAMX_ICECAST_SOURCE_PASSWORD=CHANGE_ME
RADIOAVENTURAMX_ICECAST_ADMIN_PASSWORD=CHANGE_ME
RADIOAVENTURAMX_ICECAST_RELAY_PASSWORD=CHANGE_ME
RADIOAVENTURAMX_API_KEY=CHANGE_ME
RADIOAVENTURAMX_SECRET_KEY=CHANGE_ME
RADIOAVENTURAMX_PUBLIC_URL=http://localhost:8083
